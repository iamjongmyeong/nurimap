{
  "name": "nurimap",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev --local --yes",
    "build": "tsc -b && vite build",
    "guard:bypass": "node scripts/guard-bypass-email.mjs --metadata --tracked --source-file .env.local",
    "guard:bypass:ci": "node scripts/guard-bypass-email.mjs --tracked --history-metadata --require-denylist --source-env BYPASS_EMAIL_DENYLIST",
    "lint": "eslint .",
    "preview": "vite preview",
    "setup:hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/pre-push",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/language-server": "^0.14.29",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.11",
    "@vitejs/plugin-react": "^5.1.4",
    "agentation": "^2.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "oh-my-codex": "^0.11.9",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "typescript-language-server": "^5.1.3",
    "vercel": "^50.32.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vscode-langservers-extracted": "^4.10.0"
