{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/auth/verify",
      "destination": "/"
    },
    {
      "source": "/places/:match*",
      "destination": "/"
    }
  ]
}
