# Exclude non-production files from the Vercel build context.
# Keep the default upload behavior for app/runtime sources so local `vercel deploy`
# and git-based deployments resolve the same file graph.
**/*.test.*
src/test/
docs/
supabase/
scripts/
Makefile
playwright-report/
coverage/
dist/
artifacts/
.tmp-home/
.omx/
.vercel/
.codex/
*.log
