# Upload only the files required to build and serve the production app on Vercel.
# If the build later depends on another root config file, allowlist it explicitly.
/*

# Production app source
!api/
!api/**
!public/
!public/**
!src/
!src/**

# Required root build/runtime config
!index.html
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!tsconfig*.json
!vercel.json
!vite.config.ts

# Exclude non-production source even inside allowlisted directories
**/*.test.*
src/test/
playwright-report/
coverage/
dist/
artifacts/
.tmp-home/
.omx/
.vercel/
.codex/
*.log
